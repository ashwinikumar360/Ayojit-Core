# Ayojit Intelligence — Environment Configuration
# Copy to .env and fill in values before running

# ==================================================
# Supabase (REQUIRED)
# ==================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ==================================================
# Dodo Payments (REQUIRED for paid features)
# ==================================================
DODO_API_KEY=
DODO_API_SECRET=
DODO_WEBHOOK_SECRET=
DODO_PRODUCT_PINAI=
DODO_PRODUCT_DOCPATRAM=
DODO_PRODUCT_HINDIDIFF=

# ==================================================
# Email Notifications (OPTIONAL)
# ==================================================
RESEND_API_KEY=
FROM_EMAIL=notifications@yourdomain.com
BRAND_NAME=Ayojit Intelligence

# ==================================================
# External AI Services (OPTIONAL — for production)
# ==================================================
HF_SPACE_WHISPER=
HF_SPACE_TTS=
POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt

# ==================================================
# Frontend Customization
# ==================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=false

# White-label overrides (leave blank for defaults)
NEXT_PUBLIC_BRAND_NAME=
NEXT_PUBLIC_BRAND_TAGLINE=
NEXT_PUBLIC_BRAND_COLOR=
NEXT_PUBLIC_BRAND_COLOR_LIGHT=
NEXT_PUBLIC_BRAND_LOGO_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_DASHBOARD_TITLE=
NEXT_PUBLIC_FOOTER_TEXT=

# ==================================================
# Internal API URLs (for docker-compose networking)
# ==================================================
PINAI_INTERNAL_URL=http://pinai-api:8001
DOCPATRAM_INTERNAL_URL=http://docpatram-api:8002
HINDIDIFF_INTERNAL_URL=http://hindidiff-api:8004

# ==================================================
# Feature Flags
# ==================================================
DEMO_MODE=false
